# PostgreSQL — la app (Nuxt/Nitro) solo lee DATABASE_URL
# Local: postgres en tu máquina o Docker
DATABASE_URL=postgresql://user:password@localhost:5432/f1d
# Railway (staging/prod): en el servicio *web*, referenciá la variable del plugin Postgres.
#   DATABASE_URL → URL privada (RAILWAY_PRIVATE_DOMAIN) — usá esta para el deploy.
#   DATABASE_PUBLIC_URL → proxy TCP para conectar desde fuera (TablePlus, psql local), no para la app.

# Secret key to protect sync endpoints - set your own random string
SYNC_SECRET=change-me-to-a-random-string
